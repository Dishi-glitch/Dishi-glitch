<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 450 160" width="450" height="160" role="img" aria-label="Dishi-glitch's GitHub stats">
<defs><style><![CDATA[
text{font-family:'SFMono-Regular',Consolas,'Liberation Mono',Menlo,monospace}
@keyframes fadeSlide{from{opacity:0;transform:translateX(-14px)}to{opacity:1;transform:translateX(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes rankPulse{0%,100%{opacity:.85}50%{opacity:1}}
@keyframes shineX{0%{transform:translateX(-160px) skewX(-15deg)}60%,100%{transform:translateX(510px) skewX(-15deg)}}
.row{opacity:0;animation:fadeSlide .5s ease forwards}
.rk{animation:rankPulse 2.4s ease-in-out infinite}
.sh{animation:shineX 4.5s ease-in-out 2.4s infinite}
]]></style>
<linearGradient id="tg" x1="0" y1="0" x2="1" y2="0">
  <stop offset="0%"><animate attributeName="stop-color" values="#ff7eb6;#c084fc;#ff7eb6" dur="6s" repeatCount="indefinite"/></stop>
  <stop offset="100%"><animate attributeName="stop-color" values="#c084fc;#ff7eb6;#c084fc" dur="6s" repeatCount="indefinite"/></stop>
</linearGradient>
<linearGradient id="ringg" x1="0" y1="0" x2="1" y2="1">
  <stop offset="0%" stop-color="#22c55e"/><stop offset="100%" stop-color="#3b82f6"/>
</linearGradient>
<linearGradient id="shg" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#fff" stop-opacity="0"/><stop offset="50%" stop-color="#fff" stop-opacity=".07"/><stop offset="100%" stop-color="#fff" stop-opacity="0"/></linearGradient>
<clipPath id="cc"><rect x="1" y="1" width="448" height="158" rx="14"/></clipPath>
<filter id="g"><feGaussianBlur stdDeviation="2" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
</defs>
<rect x="1" y="1" width="448" height="158" rx="14" fill="#170e28" stroke="url(#tg)" stroke-width="1.5"/>
<text x="24" y="38" font-size="16" font-weight="bold" fill="url(#tg)">💫 Dishi-glitch's GitHub Stats</text>

  <!-- Metrics Layout -->
  <g class="row" style="animation-delay:0.50s">
    <text x="24" y="82" font-size="14">💻</text>
    <text x="52" y="82" font-size="13.5" fill="#c9d1d9">Total Commits:</text>
    <text x="245" y="82" text-anchor="end" font-size="14" font-weight="bold" fill="#7dd3fc">400+</text>
  </g>
  <g class="row" style="animation-delay:0.72s">
    <text x="24" y="118" font-size="14">📦</text>
    <text x="52" y="118" font-size="13.5" fill="#c9d1d9">Public Repos:</text>
    <text x="245" y="118" text-anchor="end" font-size="14" font-weight="bold" fill="#4ade80">8</text>
  </g>

<!-- S+ Rank Circle Container -->
<g transform="translate(365,96)">
  <circle r="42" fill="none" stroke="#241740" stroke-width="8"/>
  <circle r="42" fill="none" stroke="url(#ringg)" stroke-width="8" stroke-linecap="round"
    stroke-dasharray="263.89 263.89" stroke-dashoffset="263.89" transform="rotate(-90)">
    <animate attributeName="stroke-dashoffset" from="263.89" to="0" dur="1.6s" begin=".4s" fill="freeze" calcMode="spline" keySplines=".2 .8 .3 1"/>
  </circle>
  <text class="rk" y="12" text-anchor="middle" font-size="32" font-weight="bold" fill="#22c55e" filter="url(#g)">S+</text>
  <text y="58" text-anchor="middle" font-size="9.5" fill="#8b949e" opacity="0" style="animation:fadeIn .5s ease 1.4s forwards">RANK</text>
</g>

<g clip-path="url(#cc)"><rect class="sh" x="0" y="0" width="120" height="160" fill="url(#shg)"/></g>
</svg>
